# =============================================================================
# 結（ゆい）ペーパー — ローカル開発用環境変数のテンプレート
# 実際の値を入れたファイルを .env.local という名前で同じ階層に保存してください。
# .env.local は .gitignore 済みです。
# =============================================================================

# --- Supabase (yui-app と同じプロジェクトを共有) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# サーバー側で attendees をINSERT/UPDATEするため必須
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- 外部API ---
NEXT_PUBLIC_ZIPCLOUD_API_URL=https://zipcloud.ibsnet.co.jp/api/search

# --- OCR (本番デプロイ時は必須。ローカルでも撮影テストするなら必須) ---
# Google Cloud Vision API の手書きOCRに使用
# サービスアカウントJSONファイルの全文をそのまま貼り付ける（複数行可）
GOOGLE_CLOUD_CREDENTIALS_JSON={"type":"service_account",...}

# Gemini 1.5 Flash で生テキスト→構造化フィールド変換に使用
# https://aistudio.google.com/apikey で取得
GEMINI_API_KEY=your-gemini-api-key-here
